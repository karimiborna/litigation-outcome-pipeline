# SF Superior Court session ID (required for scraping)
# Get it by visiting https://webapps.sftc.org/cc/CaseCalendar.dll in your browser
# and copying the SessionID from the URL. Expires after ~10 min of inactivity.
SFTC_SESSION_ID=your-session-id-here

# NVIDIA API key for vision-based OCR on scanned PDFs
# Get a free key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here

# Court scraper settings
SCRAPER_RATE_LIMIT_SECONDS=2.5
SCRAPER_MAX_DAILY_REQUESTS=200
SCRAPER_USER_AGENT=MSDS603-Research-Scraper/1.0 (SF Small Claims academic study)

# Data paths (defaults work for local dev)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed

# LLM for feature extraction
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-openai-key-here
LLM_BASE_URL=
FEATURES_CACHE_DIR=data/features_cache

# Embedding model for retrieval
EMBEDDING_MODEL=all-MiniLM-L6-v2
RETRIEVAL_INDEX_PATH=data/retrieval_index

# MLflow
MLFLOW_TRACKING_URI=http://34.61.152.158:5000
MLFLOW_ARTIFACT_ROOT=mlruns/artifacts

# Vercel Frontend Deployment
# API endpoint for LexRatio frontend (set in Vercel project settings)
# If not set, frontend will auto-detect based on current location
REACT_APP_API_URL=https://your-backend-domain.com/api/analyze-lexratio

